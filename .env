# PostgreSQL (create database `smart_parking` first)
DATABASE_URL=postgresql://postgres:1347@localhost:5432/smart_parking

# JWT session cookie — generate a strong secret for production, e.g.:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Parking pricing (₹)
DEFAULT_PRICE_PER_HOUR=50.0
EXTRA_RATE_PER_MINUTE=2.0
WARNING_MINUTES_BEFORE_END=10

# Display times in UI (IANA name)
DISPLAY_TIMEZONE=Asia/Kolkata

# Windows: uncomment and set if Tesseract is not on PATH
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Optional: path to a YOLO .pt trained for license plates
# YOLO_PLATE_WEIGHTS=
